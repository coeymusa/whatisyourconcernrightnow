# --- Supabase (optional) -----------------------------------------------------
# When set, /api/concerns persists to and reads from your Supabase project.
# When unset, the app falls back to in-memory + seed data (good for local dev).
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Cloudflare Turnstile (optional spam shield) -----------------------------
# When NEXT_PUBLIC_TURNSTILE_SITE_KEY is set, the form renders the widget.
# When TURNSTILE_SECRET is set, the server verifies the token on POST.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=

# --- Donate link (optional) --------------------------------------------------
# Paste a Stripe Payment Link, BuyMeACoffee URL, or any donation URL.
# When set, a small "support" link appears in the top bar + a block CTA in
# the manifesto footer. Leave blank to hide.
NEXT_PUBLIC_DONATE_URL=

# --- Misc --------------------------------------------------------------------
# Salt used when hashing IPs for rate-limiting; rotate if compromised.
IP_HASH_SALT=change-me
